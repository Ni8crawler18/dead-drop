# ============================================
# SUI NETWORK
# ============================================
SUI_NETWORK=localnet

# Custom RPC URL (optional, defaults based on network)
# SUI_RPC_URL=http://127.0.0.1:9000

# ============================================
# KEYS & ADDRESSES
# ============================================
ADMIN_ADDRESS=
SPONSOR_ADDRESSES=

ADMIN_PRIVATE_KEY=
PLAYER_A_PRIVATE_KEY=
PLAYER_B_PRIVATE_KEY=

# ============================================
# PACKAGE IDS (populated after deployment)
# ============================================
WORLD_PACKAGE_ID=
BUILDER_PACKAGE_ID=
EXTENSION_CONFIG_ID=

# ============================================
# DEAD DROP (populated after deployment)
# ============================================
DEAD_DROP_PACKAGE_ID=
DEAD_DROP_CONFIG_ID=
DEAD_DROP_REGISTRY_ID=
DEAD_DROP_BOUNTY_BOARD_ID=

# Dead Drop listing parameters (for create-listing script)
# INTEL_TEXT=Secret coordinates: sector 7G, grid 42-19
# INTEL_TITLE=Hidden Resource Cache Location
# INTEL_CATEGORY=coordinates
# PRICE_TYPE_ID=1
# PRICE_QUANTITY=10
# EXPIRY_HOURS=0

# Dead Drop bounty parameters (for post-bounty script)
# BOUNTY_DESCRIPTION=Looking for resource cache coordinates in sector 7
# BOUNTY_CATEGORY=coordinates
# REWARD_TYPE_ID=1
# REWARD_QUANTITY=20

# ============================================
# TENANT
# ============================================
TENANT=dev
